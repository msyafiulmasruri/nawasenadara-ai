# --- Server ---
HOST=0.0.0.0
PORT=8001
ENVIRONMENT=development

# --- CORS: origin Express backend (nawasenadara-backend) yang boleh memanggil service ini ---
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# --- Model NLP ---
# Folder tempat config.json / tokenizer*.json / bobot model
# (model.safetensors) IndoBERT sentimen disimpan. Default: folder
# model/ persis di root proyek ini (samakan dengan struktur folder
# hasil trainer.save_model() kamu).
SENTIMENT_MODEL_DIR=./model
MAX_SEQUENCE_LENGTH=128

# --- Groq (chatbot konseling) ---
# Ambil API key gratis di https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Keamanan internal ---
# Dicek lewat header X-Internal-Api-Key di setiap request dari backend
# Express, supaya service ini tidak bisa dipanggil sembarang orang dari
# luar (service ini TIDAK didesain untuk diekspos langsung ke publik/
# frontend — hanya dipanggil server-to-server dari nawasenadara-backend).
INTERNAL_API_KEY=
